{
    "version": "1.13.2",
    "description": "A markdown editor downloaded by mirror",
    "homepage": "https://typoraio.cn",
    "license": {
        "identifier": "Proprietary",
        "url": "https://support.typora.io/License-Agreement/"
    },
    "suggest": {
        "pandoc": "pandoc",
        "See-Yue-Typora": "chenwb-scoop-bucket/See-Yue-Typora"
    },
    "notes": [
        "Download from typoraio.cn mirror site.",
        "The configuration files and user data are stored in persistent directory.",
        "run 'scoop install chenwb-scoop-bucket/See-Yue-Typora' to install See Yue theme for Typora.",
        "If you want to remove the configuration files and user data when uninstalling, run 'scoop uninstall typora-cn -p'."
    ],
    "architecture": {
        "64bit": {
            "url": "https://downloads.typoraio.cn/windows/typora-setup-x64-1.13.2.exe",
            "hash": "ec56b1949b1bb75b7eb62ea283b04f66359eb51049d054e93e91a05a9b7168d4"
        },
        "32bit": {
            "url": "https://downloads.typoraio.cn/windows/typora-setup-ia32-1.13.2.exe",
            "hash": "b929a53556b51d5e5aa97d2544235f2814c4efad927a37be2e33e17eaf4e37fc"
        },
        "arm64": {
            "url": "https://downloads.typoraio.cn/windows/typora-setup-arm64-1.13.2.exe",
            "hash": "4678549e1537521f90abeb297866c574848e59aa7794dfc86577cc8c344e767c"
        }
    },
    "innosetup": true,
    "post_install": [
        ". \"$bucketsdir\\chenwb-scoop-bucket\\scripts\\Functions.ps1\"",
        "$configpath = Join-Path $env:AppData 'Typora'",
        "Move-Data_dir -data_dir $configpath -persist_dir $persist_dir"
    ],
    "pre_uninstall": [
        "if ($purge) {",
        "    Remove-Item -Recurse -Force \"$env:AppData\\Typora\"",
        "}"
    ],
    "bin": [
        [
            "Typora.exe",
            "Typora-scoop"
        ]
    ],
    "shortcuts": [
        [
            "Typora.exe",
            "Typora-scoop"
        ]
    ],
    "checkver": {
        "url": "https://typoraio.cn/releases/stable",
        "regex": "typora-setup-(?:x64|ia32|arm64)-([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.typoraio.cn/windows/typora-setup-x64-$version.exe"
            },
            "32bit": {
                "url": "https://downloads.typoraio.cn/windows/typora-setup-ia32-$version.exe"
            },
            "arm64": {
                "url": "https://downloads.typoraio.cn/windows/typora-setup-arm64-$version.exe"
            }
        }
    }
}
