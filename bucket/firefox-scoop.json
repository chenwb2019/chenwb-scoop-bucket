{
    "version": "152.0",
    "description": "a free and open-source web browser developed by the Mozilla Foundation",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://ftp.mozilla.org/pub/firefox/releases/152.0/win64/zh-CN/Firefox%20Setup%20152.0.exe#/dl.7z",
            "hash": "5c49255f346925764402c51f1434da9fefe0feeb0ccf12efdbc0de6183d223f8"
        },
        "32bit": {
            "url": "https://ftp.mozilla.org/pub/firefox/releases/152.0/win32/zh-CN/Firefox%20Setup%20152.0.exe#/dl.7z",
            "hash": "ae11612fa06384335013ea803f2e6119aacfcc25bd8d3369318f523a845c3172"
        },
        "arm64": {
            "url": "https://ftp.mozilla.org/pub/firefox/releases/152.0/win64-aarch64/zh-CN/Firefox%20Setup%20152.0.exe#/dl.7z",
            "hash": "1d0b5efd651f4b1e8978065b38b97384de1b54ead74470f75ff3f11de38a4f9b"
        }
    },
    "extract_dir": "core",
    "post_install": [
        ". \"$bucketsdir\\chenwb-scoop-bucket\\scripts\\Functions.ps1\"",
        "$profilePath = Join-Path $env:AppData 'Mozilla\\Firefox'",
        "Move-Data_dir -data_dir $profilePath -persist_dir $persist_dir"
    ],
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Mozilla Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://ftp.mozilla.org/pub/firefox/releases/$version/win64/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://ftp.mozilla.org/pub/firefox/releases/$version/SHA256SUMS",
                    "regex": "$sha256\\s+win64/zh-CN/$basename"
                }
            },
            "32bit": {
                "url": "https://ftp.mozilla.org/pub/firefox/releases/$version/win32/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://ftp.mozilla.org/pub/firefox/releases/$version/SHA256SUMS",
                    "regex": "$sha256\\s+win32/zh-CN/$basename"
                }
            },
            "arm64": {
                "url": "https://ftp.mozilla.org/pub/firefox/releases/$version/win64-aarch64/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://ftp.mozilla.org/pub/firefox/releases/$version/SHA256SUMS",
                    "regex": "$sha256\\s+win64-aarch64/zh-CN/$basename"
                }
            }
        }
    }
}
