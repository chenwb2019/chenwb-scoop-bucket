{
    "version": "1.0.19.502",
    "description": "ClashMI - A tool for managing network proxy settings.",
    "homepage": "https://clashmi.app/",
    "license": [
        "GPL-3.0 License",
        "Security Policy:'https://github.com/KaringX/clashmi?tab=security-ov-file#security-ov-file'"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/KaringX/clashmi/releases/download/v1.0.19.502/clashmi_1.0.19.502_windows_x64.zip",
            "hash": "add369f01d7f28061ee15c8464c49abe2824000c1cfad50e4c26688216fe2ef4"
        }
    },
    "post_install": [
        "if (!(Test-Path \"$dir\\portable\")) {",
        "    New-Item -ItemType Directory -Path \"$dir\\portable\" | Out-Null",
        "}"
    ],
    "pre_uninstall": [
        "stop-process -name ClashMI -ErrorAction SilentlyContinue",
        "Remove-Item \"$env:APPDATA\\clashmi\" -Recurse -Force -ErrorAction SilentlyContinue"
    ],
    "persist": "portable",
    "bin": "ClashMI.exe",
    "shortcuts": [
        [
            "ClashMI.exe",
            "ClashMI"
        ]
    ],
    "checkver": {
        "github": "https://github.com/KaringX/clashmi"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/KaringX/clashmi/releases/download/v$version/clashmi_$version_windows_x64.zip",
                "hash": {
                    "url": "https://github.com/KaringX/clashmi/releases/tag/v$version"
                }
            }
        }
    }
}
